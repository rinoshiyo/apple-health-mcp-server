<?xml version="1.0" encoding="UTF-8"?>
<!--
  Synthetic Apple Health export used by integration smoke tests.

  This file is hand-written. It contains NO real personal data, NO real
  device UUIDs, and NO real source names. Sample values (heart rate,
  step count, workout distance) are illustrative only.

  See tests/fixtures/README.md for the catalogue of fixtures and the
  policy that governs them.
-->
<HealthData locale="en_US">
